#!/usr/bin/env bb
;; ============================================================================
;; gq — the GRAPH-ARM retrieval CLI. ONE daemon socket round-trip = ONE op = ONE
;; oplog line. NOTHING else. (Owned-resolution validity guarantee (ii): this
;; wrapper speaks ONLY the daemon wire protocol — it is structurally incapable of
;; shelling racket --emit-edn / bb resolve.clj callgraph / re-projecting text.
;; It opens a TCP socket, writes one EDN request line, reads one EDN reply line.)
;;
;; Usage:
;;   gq callers <module> <name>      -> :callers reverse lookup (tasks a)
;;   gq callers-te <@mod#id>         -> :callers keyed on a node id (task b: the
;;                                      reference's ultimate target node)
;;   gq query   '<edn-query-map>'    -> :query Datalog over the warm graph (task cal)
;;   gq status                       -> :status {:version :claims :log}
;;   gq version                      -> :version
;;   gq raw     '<edn-op-map>'       -> send an arbitrary {:op ...} (boot-guard use)
;;
;; Each invocation appends EXACTLY ONE line to $GQ_LOG (if set) and is exactly one
;; socket round-trip. wc -l $GQ_LOG == graph-arm op count, by construction.
;;
;; Port from $GQ_PORT (or first env). The wrapper has NO grep/read/file-search verb.
(require '[clojure.edn :as edn]
         '[clojure.java.io :as io])
(import '[java.net Socket InetSocketAddress]
        '[java.io BufferedReader BufferedWriter InputStreamReader OutputStreamWriter])

(def port (Integer/parseInt (or (System/getenv "GQ_PORT")
                                 (do (binding [*out* *err*] (println "gq: set GQ_PORT"))
                                     (System/exit 2)))))

(defn client [m]
  ;; the daemon's own wire protocol (cnf_coord_daemon.clj:883): one line out, one in.
  (with-open [s (Socket.)]
    (.connect s (InetSocketAddress. "127.0.0.1" (int port)) 2000)
    (let [w (BufferedWriter. (OutputStreamWriter. (.getOutputStream s)))
          r (BufferedReader. (InputStreamReader. (.getInputStream s)))]
      (.write w (pr-str m)) (.newLine w) (.flush w)
      (edn/read-string (.readLine r)))))

(defn log-op! [label]
  (when-let [lg (System/getenv "GQ_LOG")]
    (spit lg (str "gq " label "\n") :append true)))

(let [[cmd & more] *command-line-args*]
  (case cmd
    "callers"   (let [[m nm] more
                      _ (log-op! (str "callers " m " " nm))
                      res (client {:op :callers :module m :name nm})]
                  (println (pr-str res)))
    "callers-te" (let [[te] more
                       _ (log-op! (str "callers-te " te))
                       res (client {:op :callers :te te})]
                   (println (pr-str res)))
    "query"     (let [[q] more
                      _ (log-op! (str "query " q))
                      res (client {:op :query :query (edn/read-string q)})]
                  (println (pr-str res)))
    "status"    (do (log-op! "status") (println (pr-str (client {:op :status}))))
    "version"   (do (log-op! "version") (println (pr-str (client {:op :version}))))
    "raw"       (let [[opmap] more
                      _ (log-op! (str "raw " opmap))
                      res (client (edn/read-string opmap))]
                  (println (pr-str res)))
    (do (binding [*out* *err*] (println "gq: unknown cmd" cmd
                                        "(callers|callers-te|query|status|version|raw)"))
        (System/exit 2))))
