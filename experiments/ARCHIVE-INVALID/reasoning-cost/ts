#!/usr/bin/env bash
# ============================================================================
# ts — the TEXT-ARM retrieval CLI for the tier-2 reasoning-cost experiment.
#
# It wraps EXACTLY TWO retrieval primitives, each performing ONE retrieval and
# appending ONE line to $TS_LOG:
#
#   ts search "<regex>" [path]   -> ONE ripgrep pass over the source     = 1 op
#   ts read   <file> [a:b]       -> ONE file (or line-range) read         = 1 op
#
# The metric is `wc -l "$TS_LOG"` and it EQUALS the retrieval count by
# construction:
#   - Each subcommand performs exactly one primitive and logs exactly one line.
#   - There is NO raw-shell subcommand: a subject cannot cram ten greps into one
#     invocation. A SINGLE alternation regex inside one `ts search` is ONE pass
#     (allowed — a real engineer writes `rg '(k/)?Claim'`); ten *separate*
#     searches are ten `ts search` calls and ten log lines (anti-gaming targets
#     compound COMMANDS, not single-pass alternation — METHODOLOGY guard 2).
#   - This wrapper speaks ONLY ripgrep/file-read; it can NOT shell the daemon,
#     racket --emit-edn, or resolve.clj. (The graph arm is gquery; the oracle is
#     computed once, separately.)
#
# Usage requires TS_LOG to be set (the arm-specific oplog file).
# ============================================================================
set -euo pipefail

RG="$(command -v rg)"
if [ -z "${RG:-}" ]; then
  echo "ts: ripgrep (rg) not found on PATH" >&2
  exit 2
fi

if [ -z "${TS_LOG:-}" ]; then
  echo "ts: TS_LOG is not set (the per-arm oplog path is required)" >&2
  exit 2
fi

# Ensure the oplog file exists so wc -l is well-defined even before the first op.
: >>"$TS_LOG"

log_op() {
  # One line per retrieval. Field-separated, machine-parseable, non-gameable:
  # the count is `wc -l "$TS_LOG"`.
  printf '%s\t%s\t%s\n' "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" "$1" "$2" >>"$TS_LOG"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  search)
    # ts search "<regex>" [path...]
    # ONE ripgrep pass. -o (only-matching is OPTIONAL via --only); default is a
    # line-oriented search with line numbers (-n), no-filename suppressed so the
    # caller sees module + line (it is reconstructing structure). Exactly ONE
    # regex (alternation allowed); ripgrep is invoked exactly once.
    only=0
    if [ "${1:-}" = "--only" ]; then only=1; shift; fi
    pat="${1:-}"
    if [ -z "$pat" ]; then
      echo "ts search: missing <regex>" >&2; exit 2
    fi
    shift || true
    # Remaining args are paths; default to the frozen corpus if none given.
    if [ "$#" -eq 0 ]; then
      set -- "${TS_CORPUS:-/home/tom/code/fram/src/fram}"
    fi
    log_op "search" "$pat"
    # -e fixes the pattern as a regexp arg (so a leading '-' in the pattern is
    # never parsed as a flag); --no-config keeps it deterministic; -n line nums.
    if [ "$only" -eq 1 ]; then
      # only-matching, no line numbers, no filename: token enumeration mode.
      "$RG" --no-config -o -I -N -e "$pat" "$@" || true
    else
      # default: line-oriented, with file + line number (structure-recovery mode)
      "$RG" --no-config -n --no-heading -e "$pat" "$@" || true
    fi
    ;;

  read)
    # ts read <file> [a:b]   — ONE file or line-range read.
    file="${1:-}"
    rng="${2:-}"
    if [ -z "$file" ]; then
      echo "ts read: missing <file>" >&2; exit 2
    fi
    if [ ! -f "$file" ]; then
      echo "ts read: no such file: $file" >&2; exit 2
    fi
    if [ -n "$rng" ]; then
      log_op "read" "$file $rng"
      a="${rng%%:*}"; b="${rng##*:}"
      # ONE read of the requested line range (inclusive), with line numbers.
      "$RG" --no-config -n --no-heading -e '' "$file" \
        | awk -F: -v a="$a" -v b="$b" '($1+0)>=a && ($1+0)<=b' || true
    else
      log_op "read" "$file"
      "$RG" --no-config -n --no-heading -e '' "$file" || true
    fi
    ;;

  count)
    # convenience read-only of the current op count (NOT a retrieval; not logged)
    wc -l <"$TS_LOG"
    ;;

  *)
    echo "ts: unknown subcommand '${cmd:-}'. use: search | read | count" >&2
    exit 2
    ;;
esac
