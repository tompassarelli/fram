 ;; ---- the WARM-session amortization frame (the precondition of the per-query claim) ----
 ;; SYMMETRIC across arms. State it once; apply it everywhere.
 :amortization
 {:precondition "WARM daemon already running (the deployed-lodestar scenario). The per-query op-count
                 claim is about a warm session; in a COLD single-question session the graph LOSES
                 (it pays the full ~37s setup for one query). We say so."
  :graph-setup-amortized "the ~37s projection+boot+resolve is paid ONCE, ~0/query thereafter"
  :text-alias-amortized  "SYMMETRICALLY: the agent learns each module's :as k alias ONCE; the
                          :learned-alias map is given to BOTH arms at setup. Alias-discovery is
                          NOT charged per task (that would be asymmetric amortization favoring the graph)."
  :learned-alias {:k "fram.kernel (aliased :as k by export fold import main query tools; datalog/schema do NOT)"}}

 ;; ---- the ONE-TIME setup the graph pre-pays (NOT a per-query retrieval) — VERIFIED end-to-end ----
 ;; This is the legitimate "graph pre-pays once" cost AND the ONLY point text is parsed for the graph arm.
 :graph-setup
 {:project    "for each .bclj: racket ~/code/beagle/beagle-lib/private/claims-roundtrip.rkt --emit-edn <mod.bclj>"
  :emit-format "emit-edn yields bare [id pred value] triples + an `@file` header + PER-FILE integer ids"
  :translate  "PROJECTION TRANSLATOR: convert each [id pred value] -> {:tx N :op \"assert\" :l \"@<module>#<id>\"
               :p \"<pred>\" :r <r>}, NAMESPACING node ids by module (@kernel#1518) so 11 files' ints don't collide;
               quote literals as EDN strings; ref-string edges as \"@module#<id>\" (daemon ref-str? = string starting @)."
  :translate-why "migrate-flat->co reads fram.rt/read-log = one EDN map/line {:tx :op :l :p :r}
                  (cnf_coord_daemon.clj:922; src/fram/rt.clj:144-157). emit-edn's vectors must be translated. VERIFIED:
                  translator emits a 78565-line flat log; daemon folds it to 101671 live claims."
  :to-claims  "append ALL 11 modules' translated lines to ONE temp flat log (the daemon's canonical artifact)"
  :boot       "clojure -M cnf_coord_daemon.clj serve-flat <PORT> <TEMP-LOG>   (or bin/fram-daemon). VERIFIED: ~37s to listening."
  :materialize "first :callers triggers ensure-refers! -> resolve/resolve-warm-store! (cnf_coord_daemon.clj:463) ->"
  :materialize-effect "the lexical walk materializes refers_to OVER THE WARM STORE; queries READ it, never recompute from text"
  :boot-guard "{:op :status} claims>0 AND :log==TEMP-LOG ; {:op :callers {:module kernel :name thread-ids-i}} nonempty"
  :boot-guard-observed
  {:status  "{:version 78565, :claims 101671, :log \"<temp>/corpus.flatlog\"}   ; VERIFIED"
   :callers-thread-ids-i "{:callers [[\"tools\" \"k/thread-ids-i\"] [\"kernel\" \"thread-ids-i\"] [\"main\" \"k/thread-ids-i\"]],
                          :target \"@kernel#1518\"}   ; VERIFIED nonempty, incl the intra-kernel caller"
   :callers-Claim "{:callers [ ... 10 distinct [module rendered] groups across k/Claim, Claim, ->Claim ...],
                   :target \"@kernel#298\"}   ; VERIFIED — the defrecord resolves; all 3 spellings, one identity"
   :unbuilt-ops "{:op :reaches} -> {:error \"unknown op\"} ; {:op :type-refs} -> {:error \"unknown op\"}  ; VERIFIED (c/d not live)"}}

 ;; ---- the two retrieval substrates (the ONLY thing that differs between arms) ----
 :substrates
 {:text  {:primitives ["tsearch <regex> [path]  ; ONE source search (alternation allowed = ONE pass) -> 1 op"
                        "tread   <file> [a:b]    ; ONE file/range read -> 1 op"]
          :over   "the .bclj SOURCE (and, ONLY for task d's source-UNAVAILABLE sub-case, the lowered out/*.clj)"
          :no-raw-shell true                       ; compound-grep gaming structurally impossible
          :alternation-allowed "a SINGLE regex with alternation is ONE search pass = 1 op (NOT batching).
                                Anti-gaming targets COMPOUND COMMANDS (grep a; grep b), not single-pass alternation."
          :oplog  "text.oplog — one line per primitive; wc -l == op count"}
  :graph {:primitive "gquery <op> {...}  ; ONE daemon socket round-trip -> 1 op (cnf_coord_daemon.clj:883)"
          :over   "the live daemon over the warm claim graph (refers_to MATERIALIZED at setup; read, not recomputed)"
          :ops    [:callers :query :status :version]   ; the ONLY ops the wrapper may emit
          :cannot "shell racket/bb/resolve.clj — the wrapper speaks ONLY the daemon wire protocol (guarantee ii)"
          :live-serves [:cal :a :b]                ; refers_to-backed via :callers (cnf_coord_daemon.clj:606,736) — VERIFIED
          :layer-a-only [:c :d]                    ; :reaches/:type-refs are 'unknown op' (VERIFIED); graph cost = HYPOTHETICAL
          :oplog  "graph.oplog — one line per round-trip; wc -l == op count"}}
  ;; NOTE: NO :resolver-callgraph here. The callgraph CLI is the once-computed ORACLE
  ;; (see :ground-truth), never a graph-arm retrieval. (audit Q4 required-fix #2.)

 ;; ---- the principled daemon extension that would make (c)/(d) LIVE (documented, not faked) ----
 :live-cd-path
 {:why "today the warm store materializes refers_to but NOT a calls-defn edge, and :query filters refers_to"
  :verified "{:op :reaches} and {:op :type-refs} both return {:error \"unknown op\"} (the ops do not exist yet)"
  :filter-site "cnf_coord_daemon.clj:50 (resolve-preds) + :174 (claim->triple drops resolve-preds from read view)"
  :extension "materialize a calls-defn relation into the warm store in resolve-warm-store! (analogous to refers_to),"
  :extension-2 "and add daemon ops :reaches / :blast / :type-refs that READ those WARM claims (analogous to :callers)"
  :result "when it lands, (c)/(d) move into the LIVE graph headline by construction and the HYPOTHETICAL '1' becomes MEASURED"
  :forbidden "routing (c)/(d) through `bb resolve.clj callgraph` as a graph-arm retrieval to 'make them live' (audit Q4)"}

 ;; ---- held IDENTICAL across both arms (everything except the substrate) ----
 :held-constant
 ["the corpus (one frozen mktemp copy per run)"
  "the agent harness + model"
  "the task prompt (verbatim) and the required answer shape"
  "the STARTING CONTEXT incl the :learned-alias map (given to BOTH arms — warm-session frame)"
  "the SUBSTRATE-BLIND STOPPING RULE: 'stop when you can name the full answer set required by the prompt'
   (NOT self-terminate-on-confidence — that would let model temperament leak in as a fake substrate advantage)"
  "the ground-truth scorer (same oracle for both)"]

 ;; ---- ground truth + recompile oracle (computed ONCE; same for both arms) ----
 :ground-truth
 {:callgraph "bb -cp out chartroom/src/resolve.clj callgraph <emitted-EDN>  ; :edges scope-correct, :blast transitive
              (resolve.clj:1219-1273). NB callgraph LOADS emitted EDN (not .bclj directly); node keys are file#offset."
  :callers   "gquery :callers {:module .. :name ..}  ; cnf_coord_daemon.clj:736 (reverse refers_to lookup, live)"
  :ultimate  "resolver ultimate(refers_to(ref)) rendered via callers-of-in-store markers ; cnf_coord_daemon.clj:606"
  :type-refs "resolved :- (Vec Claim) annotations whose inner type ultimate-resolves to kernel Claim ; resolve.clj walk-type (191-205)"
  :oracle    "~/code/beagle/bin/beagle-build-all <dir> --out <o> 2>&1 | grep -iE 'built, .* error'"
  :oracle-pass-predicate "parse the count; EXACTLY 0 errors. NEVER str-includes '0 error' (passes 'built, 10 error(s)')."}

