                 lowered: grep -rhoE 'Vec Claim' out/fram/*.clj | wc -l (=0) ;  grep -rn '\\^Claim' out/fram/*.clj (=4 surviving single-param hints)"}

  ;; --------------------------------------------------------------------------
  ;; (e) EDIT-PROPAGATION COROLLARY — rename and make it recompile. Tier-1's rename result
  ;; re-expressed as a COST count. Scored by the recompile ORACLE. EDIT-cost, reported SEPARATELY
  ;; from the (a)-(d) read-cost headline. CONCESSION KEPT: a perfect single sed matches in isolation.
  {:id    :e
   :hops  :k
   :served :edit
   :title "rename Claim -> Datum and make it recompile"
   :prompt "Rename the kernel record `Claim` to `Datum` everywhere it is referenced, such that the corpus still recompiles (11 built, 0 error(s))."
   :target {:module "kernel" :name "Claim"}
   :ground-truth-source {:via   "the Beagle compiler — the rename is correct iff beagle-build-all reports EXACTLY 0 errors"
                         :graph-edit "bb -cp out chartroom/src/resolve.clj rename Claim Datum kernel  (supersedes ONE binding-name claim;
                                      resolve.clj:1014-1075 -> 'CLAIMS EDITED: 1' VERIFIED at :1075)"
                         :measured "CLAIMS EDITED: 1 ; every refers_to reference re-renders the binding's CURRENT name (all 74 tokens re-point)"}
   :graph {:ops 2
           :sequence
           ["1 EDIT: rename Claim Datum kernel  (one identity edit — supersedes ONE binding-name claim; all 74 references re-point by refers_to)"
            "1 VERIFY: beagle-build-all -> '11 built, 0 error(s)'  (the recompile oracle confirms)"]
           :note "rename is O(1) at the graph: one claim superseded. References render the new name for free, exactly under shadowing.
                  NOT counted as a retrieval op in the a-d read-cost headline."}
   :text-minimal {:ops ">= 3 (find-all-spellings-in-one-pass + global-edit + recompile-verify + fix-any-miss)"
                  :sequence
                  ["the STRONGEST source replace: sed -E 's/\\bClaim\\b/Datum/g' over .bclj  (catches bare + k/Claim + the ->Claim base name)"
                   "RECOMPILE: beagle-build-all (1)"
                   "if the compiler surfaces a missed reference -> tread the failing site (1) -> re-edit -> recompile again (1)  (the backtrack loop)"]
                  :justification
                  "The STRONGEST source find/replace catches all Claim tokens; the agent must still recompile to CONFIRM zero misses.
                   Each compiler-surfaced miss is a real backtrack."
                  :concession "The sibling proved a perfect single sed over source catches all Claim tokens and recompiles clean (the FILE
                               arm WINS the stand-alone rename in isolation). The graph's structural win on (e) is identity O(1) +
                               zero-miss-by-construction; the text win-condition requires a globally-correct replace with no spelling
                               missed, plus the recompile-verify loop. We CONCEDE the isolated-sed parity explicitly."}
   :verdict "GRAPH: 1 identity edit + 1 verify, zero misses by construction. TEXT: strongest-sed + recompile + fix-misses
             (CONCEDED: a perfect sed can match in isolation). Scored by the compiler (exactly 0 errors). Reported as EDIT-cost,
             separate from the read-cost headline."
   :measured-by "bb -cp out chartroom/src/resolve.clj rename Claim Datum kernel  (reports CLAIMS EDITED: 1) ; then beagle-build-all"}]

 ;; ---- the two evidence layers (they prove DIFFERENT things — see METHODOLOGY) ----
 :evidence-layers
 {:A-deterministic
  {:what "scripted per-task op-count: the single graph query (LIVE-measured for a/b; HYPOTHETICAL for c/d) vs the
          minimal-correct text reconstruction (alternation allowed, alias amortized)"
   :property "model-INDEPENDENT because the AGENT IS REMOVED -> a STRUCTURAL LOWER-BOUND PROOF about THIS corpus, NOT a
              measurement of agent behavior. The op-counts are AUTHORED (justified op-by-op), the FLOOR — not what an agent does."
   :output "a per-task table: (task, hops, served, graph-ops [live|HYPOTHETICAL], text-ops, both-correct?), with c/d VISUALLY SEGREGATED"
   :fairness "text path re-derived DOWN to the ripgrep floor (a:2, b:2, d-source:3); each op tied to a MEASURED obstacle; never padded, never oracle-fed"}
  :B-behavioral
  {:what "real paired sub-agents (text arm / graph arm), each WRAPPER-CONFINED (NO Bash/Read/Grep), on the LIVE tasks a, b (and d as a text accuracy demo)"
   :the-only-empirical-claim "B is the ONLY layer that observes a real agent. The HEADLINE empirical sentence is a B DISTRIBUTION."
   :stopping-rule "SUBSTRATE-BLIND: 'stop when you can name the full answer set' (NOT self-terminate-on-confidence — blocks temperament leak)"
   :N ">= 10 per task per arm (N=3 cannot separate substrate-signal from agent-variance)"
   :bypass-detector "DISCARD (do not score) any transcript whose observed-retrievals != wc -l oplog, or that used a tool outside the wrapper set"
   :property "stochastic — report min/median/max op-count + correct-answer RATE; run-to-run variance disclosed honestly"
   :output "per task per arm: op-count DISTRIBUTION + accuracy"
   :relation-to-A "B may land ABOVE A (flail). If B lands below A in op-count it skipped required work -> the correctness scorer catches it.
                   A is the fair model-free FLOOR; B is the visceral empirical claim."
   :live-served "a, b run LIVE gquery; d is a text-arm source-vs-lowered accuracy demo (graph cost = oracle HYPOTHETICAL, guarantee iii)"}}

 ;; ---- correctness held constant ----
 :scoring
 {:per-cell "(op-count, correct?) — correctness scored vs :ground-truth-source (resolver/daemon) or, for task e, the recompile oracle"
  :headline-cell "same correct answer, N_graph ops vs N_text ops"
