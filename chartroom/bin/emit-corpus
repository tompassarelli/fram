#!/usr/bin/env bash
# emit-corpus: project a beagle source tree into a CNF claim stream.
#   bin/emit-corpus <src-dir> [out.claims]
# Defaults to gjoa src -> build/gjoa.claims.
set -o pipefail
BEAGLE="${BEAGLE:-$HOME/code/beagle}"
src="${1:-$HOME/code/gjoa/src/gjoa}"
out="${2:-$(dirname "$0")/../build/gjoa.claims}"
mkdir -p "$(dirname "$out")"
"$BEAGLE/bin/beagle-facts" "$src" > "$out"
echo "emit-corpus: $(grep -c '^@file' "$out") files, $(grep -c '^\[' "$out") claims -> $out" >&2
