# fram-shim image — the bearer-token HTTP->TCP bridge (shim.clj) on babashka.
# Build from the repo root:
#   docker build -f deploy/cloudflare/Dockerfile.shim -t fram-shim .
FROM babashka/babashka:latest

WORKDIR /shim
COPY deploy/cloudflare/shim.clj ./

EXPOSE 8787
# config via env: FRAM_HOST, FRAM_PORT, SHIM_PORT, SHIM_TOKEN | SHIM_TOKEN_FILE
CMD ["bb", "shim.clj"]
