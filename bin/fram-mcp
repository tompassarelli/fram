#!/usr/bin/env bash
# Fram MCP server — the AI-facing edge of one instance. Speaks MCP (JSON-RPC 2.0
# over stdio). The surface is the CLOSED TELL/ASK knowledge-base catalog — exactly
# ten tools: tell / retract / show / ask / validate + the five graph-edit verbs
# (add-def / set-body / rename-def / insert-after / replace-in-body). It is never
# minted per-predicate: the vocabulary is DATA in the graph (a predicate is an
# entity — `show <pred>` reveals its cardinality/value_kind), so the tool count is
# O(1). `untell` is accepted as an alias for `retract`, `query` for `ask`. Reads
# fold the log; writes route through the coordinator. Point a model's MCP client
# at this command.
#
#   FRAM_THREADS / FRAM_LOG select the corpus; FRAM_TELEMETRY_LOG optionally
#   names its split telemetry half. Reads fold the pair into one logical store.
HERE="$(cd "$(dirname "$0")/.." && pwd)"
if [[ "${FRAM_PACKAGED:-0}" == "1" ]]; then
  if [[ -z "${FRAM_LOG:-}" || -z "${FRAM_THREADS:-}" ]]; then
    if [[ -n "${FRAM_STATE_DIR:-}" ]]; then
      state_dir="$FRAM_STATE_DIR"
    elif [[ -n "${XDG_STATE_HOME:-}" ]]; then
      state_dir="$XDG_STATE_HOME/fram"
    elif [[ -n "${HOME:-}" ]]; then
      state_dir="$HOME/.local/state/fram"
    else
      echo "fram-mcp: set FRAM_LOG + FRAM_THREADS, FRAM_STATE_DIR, XDG_STATE_HOME, or HOME" >&2
      exit 2
    fi
  fi
  [[ -n "${FRAM_THREADS:-}" ]] || FRAM_THREADS="$state_dir/threads"
  [[ -n "${FRAM_LOG:-}" ]] || FRAM_LOG="$state_dir/coordination.log"
else
  FRAM_THREADS="${FRAM_THREADS:-$HERE/threads}"
  FRAM_LOG="${FRAM_LOG:-$HERE/coordination.log}"
fi
export FRAM_THREADS FRAM_LOG
mkdir -p "$FRAM_THREADS" "$(dirname "$FRAM_LOG")"
# Pin beagle's racket (matches the emit-edn .zo bytecode) onto PATH so the
# facts-roundtrip --emit-edn/--render calls in the edit channel never hit an
# ambient version-skewed racket (-> .zo "version mismatch"). FRAM_RACKET
# overrides; mirrors bin/_beagle-racket. Covers fram_mcp.clj + every bb helper it
# spawns (fram-commit-code / fram-render-code / ...), which inherit PATH.
BEAGLE_HOME="${BEAGLE_HOME:-${HOME:+$HOME/code/beagle}}"
_pinned_racket="${FRAM_RACKET:-}"
if [[ -z "$_pinned_racket" && -n "$BEAGLE_HOME" ]]; then
  _pinned_racket="$(direnv exec "$BEAGLE_HOME" which racket 2>/dev/null || true)"
fi
if [ -n "$_pinned_racket" ]; then
  PATH="$(dirname "$_pinned_racket"):$PATH"
  export PATH
fi
cd "$HERE" && exec bb -cp out tests/fram_mcp.clj
