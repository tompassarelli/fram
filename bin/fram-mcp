#!/usr/bin/env bash
# Fram MCP server — the AI-facing edge of one instance. Speaks MCP (JSON-RPC 2.0
# over stdio). Default surface is the TELL/ASK knowledge-base core (tell / untell
# / show / ask + threads / validate + the graph-edit verbs, ~10 tools);
# FRAM_MCP_SURFACE=full serves the per-predicate catalog generated from the
# current log's claim vocabulary (fram.tools). tools/call accepts both namings on
# every surface. Reads fold the log; writes route through the coordinator. Point
# a model's MCP client at this command.
#
#   FRAM_THREADS / FRAM_LOG select the corpus (same vars the CLI reads).
HERE="$(cd "$(dirname "$0")/.." && pwd)"
export FRAM_THREADS="${FRAM_THREADS:-$HERE/threads}"
export FRAM_LOG="${FRAM_LOG:-$HERE/claims.log}"
# Pin beagle's racket (matches the emit-edn .zo bytecode) onto PATH so the
# claims-roundtrip --emit-edn/--render calls in the edit channel never hit an
# ambient version-skewed racket (-> .zo "version mismatch"). FRAM_RACKET
# overrides; mirrors bin/_beagle-racket. Covers fram_mcp.clj + every bb helper it
# spawns (fram-commit-code / fram-render-code / ...), which inherit PATH.
BEAGLE_HOME="${BEAGLE_HOME:-$HOME/code/beagle}"
_pinned_racket="${FRAM_RACKET:-$(direnv exec "$BEAGLE_HOME" which racket 2>/dev/null || true)}"
[ -n "$_pinned_racket" ] && export PATH="$(dirname "$_pinned_racket"):$PATH"
cd "$HERE" && exec bb -cp out tests/fram_mcp.clj
