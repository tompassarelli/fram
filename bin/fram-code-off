#!/usr/bin/env bash
# fram-code-off <dir> — turn the graph stack OFF: kill the coordinator serving
# this dir's code.log + remove the .mcp.json. Inverse of fram-code-on.
set -uo pipefail
DIR="${1:?usage: fram-code-off <dir>}"; DIR="$(cd "$DIR" && pwd)"
CODE_LOG="$DIR/.fram/code.log"
# kill the coordinator that serves THIS code.log (matched precisely, not by port)
pkill -f "coord_daemon.clj serve-flat .* $CODE_LOG" 2>/dev/null && echo "coordinator stopped" || echo "no coordinator running for $CODE_LOG"
rm -f "$DIR/.mcp.json"
echo "fram-code-off: $DIR — .mcp.json removed. (code.log kept at $CODE_LOG; delete .fram/ to fully reset.)"
