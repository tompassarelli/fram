#!/usr/bin/env bb
;; ============================================================================
;; fram-edit-code — THE FLIP, the CORE: an authoring edit sourced FROM the graph.
;; ============================================================================
;; The inversion. The legacy edit path (fram_mcp.clj route-edit) emit-edn's every
;; src/fram/*.bclj into a FRESH store, runs the verb over that TEXT-derived AST,
;; renders, and commits a delta computed from regenerated text — so the graph is
;; DOWNSTREAM of text. This is the opposite:
;;
;;   1. boot a reified store FROM .fram/code.log (migrate-flat->co — the SAME boot
;;      fram-render-code uses; in-process, no socket). This store IS the corpus.
;;   2. run the authoring verb (rename / set-body / upsert-form) over THAT store
;;      via resolve.clj run-verb-warm! — the verb mints/supersedes claim ops
;;      against LOG-RESIDENT node identity (@<mod>#int), never reading any .bclj.
;;      corpus-from-store! derives srcs/frames from the store's `name` claims, so
;;      the verb resolves cross-module references against the WHOLE-LOG corpus.
;;   3. render the affected module FROM the mutated store (extract-file! already
;;      wrote the resolved EDN under $RESOLVE_OUT) -> .bclj, written ATOMICALLY
;;      (temp + fsync + rename — B1: a failed render can never truncate a file).
;;   4. commit the AST delta THROUGH the coordinator (bin/fram-commit-code, the
;;      serialized single-(te,p,r) :assert/:retract wire) so the log is updated.
;;      The .bclj fed to fram-commit-code is render(LOG), NOT a src/fram file —
;;      so the WHOLE path reads ZERO src/fram/*.bclj.
;;
;; The recompile gate (beagle-build-all over the rendered module) is the caller's
;; responsibility (fram_mcp.clj route-edit runs it before committing). This script
;; renders + commits; pass --no-commit to render-only (the gate's pre-step).
;;
;; USAGE:
;;   bin/fram-edit-code <op> <module> [verb args] --port <P> [--log <code.log>]
;;                                                [--out <file.bclj>] [--no-commit]
;;     ops:
;;       rename      <module> --old <name> --new <name>
;;       set-body    <module> --name <defn> --body-file <edn>
;;       upsert-form <module> --spec-file <edn>
;;       insert-form <module> --after <anchor> --spec-file <edn>   (CRDT mid-insert, commute)
;;       delete      <module> --name <def>                         (fail-closed: refuses if it orphans a ref)
;;       reorder     <module> --name <def> [--after <anchor>]      (move in place — re-spell order key, no node churn; no --after = front)
;;     --port   REQUIRED unless --no-commit — coordinator serving the CODE log.
;;     --log    code log to boot the store from (default $PWD/.fram/code.log).
;;     --out    where to write the rendered .bclj (default: a temp file path is
;;              printed). The committed log is canonical; --out is just the view.
;;     --no-commit  render the affected module from the (in-memory) edited store
;;                  and stop — do NOT commit (used as the recompile-gate pre-step).
;;
;; SAFETY: --port must serve a *code.log (fram-commit-code asserts this). NEVER
;; the live tern coordinator. NO src/fram/*.bclj is read on this path.
;; Env: BEAGLE_HOME, FRAM_ROUNDTRIP, FRAM_RESOLVE, FRAM_BIN, FRAM_OUT.
;; ============================================================================
(require '[clojure.string :as str]
         '[clojure.java.io :as io]
         '[clojure.edn :as edn]
         '[babashka.process :as proc]
         '[fram.store :as c]
         '[fram.schema :as s])
(import '[java.nio.file Files CopyOption StandardCopyOption]
        '[java.io File FileOutputStream RandomAccessFile])

(defn- die [& xs] (binding [*out* *err*] (apply println xs)) (System/exit 1))
(defn- log! [& xs] (binding [*out* *err*] (apply println xs)))

(def ^:private home (System/getProperty "user.home"))
(def ^:private beagle-home   (or (System/getenv "BEAGLE_HOME") (str home "/code/beagle")))
(def ^:private roundtrip-rkt (or (System/getenv "FRAM_ROUNDTRIP")
                                 (str beagle-home "/beagle-lib/private/claims-roundtrip.rkt")))
;; D3: the legacy cold-render path (`racket --render`) loads claims-roundtrip's .zo,
;; compiled for beagle's flake-pinned racket; bare "racket" risks a .zo version mismatch.
;; Resolve the pinned racket like bin/fram-ingest-code (FRAM_RACKET overrides). NO bare
;; fallback — fail loud rather than emit a stale-bytecode failure that looks like a bug.
(def ^:private racket-bin
  (or (System/getenv "FRAM_RACKET")
      (let [r (try (proc/sh {:out :string :err :string} "direnv" "exec" beagle-home "which" "racket")
                   (catch Exception _ nil))]
        (when (and r (zero? (:exit r)) (not (str/blank? (:out r))))
          (str/trim (:out r))))
      (die (str "fram-edit-code: cannot resolve pinned racket for " beagle-home ". "
                "Run `source " beagle-home "/bin/_beagle-racket` first, or set FRAM_RACKET "
                "to the flake-pinned racket binary. Refusing to fall back to bare `racket` "
                "(version mismatch with beagle's compiled .zo bytecode)."))))
(def ^:private resolve-clj   (or (System/getenv "FRAM_RESOLVE")
                                 (str (System/getProperty "user.dir") "/chartroom/src/resolve.clj")))
(def ^:private fram-out      (or (System/getenv "FRAM_OUT") (str (System/getProperty "user.dir") "/out")))
(def ^:private bin-dir       (or (System/getenv "FRAM_BIN") (str (System/getProperty "user.dir") "/bin")))

;; resolve.clj's tail runs (-main) iff (first *command-line-args*) is a recognized
;; MODE. Our bin's own first arg (e.g. "set-body") collides with that set, AND
;; coord_daemon.clj itself load-files resolve.clj — so MASK the CLI args around
;; BOTH loads. We drive resolve.clj's verbs via run-verb-warm!, never its -main.
;; (fram-render-code is immune: its first arg is a module name, not a MODE.)
(def ^:private the-args (vec *command-line-args*))   ; capture before masking
(binding [*command-line-args* []]
  (load-file "coord_daemon.clj")          ; migrate-flat->co + warm-store machinery
  (load-file resolve-clj))                     ; run-verb-warm! / extract-file! / out-path

;; --- B1: ATOMIC write — render to a temp file in the SAME dir, fsync, then
;; rename-into-place. A partial/failed render can never truncate the live target
;; (rename is atomic on the same filesystem; the temp is fsync'd before rename).
(defn- atomic-spit! [target ^String content]
  (let [t (io/file target)
        dir (or (.getParentFile t) (io/file "."))
        tmp (File/createTempFile (str ".fram-render-" (.getName t) "-") ".tmp" dir)]
    (try
      (with-open [os (FileOutputStream. tmp)]
        (.write os (.getBytes content "UTF-8"))
        (.flush os)
        ;; fsync the temp before rename — via the FileChannel (FileDescriptor.sync
        ;; is sandboxed in bb; .force(true) on the channel is the same fsync).
        (.force (.getChannel os) true))
      (let [tp (.toPath tmp) targp (.toPath t)]
        (try
          (Files/move tp targp
                      (into-array CopyOption [StandardCopyOption/ATOMIC_MOVE
                                              StandardCopyOption/REPLACE_EXISTING]))
          (catch Exception _                            ; ATOMIC_MOVE unsupported on this FS
            (Files/move tp targp
                        (into-array CopyOption [StandardCopyOption/REPLACE_EXISTING])))))
      (finally (when (.exists tmp) (.delete tmp))))))

(defn- parse-args [args]
  (loop [a (drop 2 args)
         opts {:op (first args) :module (second args)
               :port nil :log nil :out nil :no-commit false :whole-module false
               :old nil :new nil :name nil :body-file nil :spec-file nil :after nil :text nil :placement nil}]
    (cond
      (empty? a) opts
      (= "--port" (first a)) (recur (drop 2 a) (assoc opts :port (Integer/parseInt (second a))))
      (= "--log" (first a)) (recur (drop 2 a) (assoc opts :log (second a)))
      (= "--out" (first a)) (recur (drop 2 a) (assoc opts :out (second a)))
      (= "--no-commit" (first a)) (recur (rest a) (assoc opts :no-commit true))
      ;; opt OUT of the minimal-op path back to the legacy cold-boot whole-module
      ;; render+diff+commit (the ~7800-op baseline). Default is the minimal path.
      (= "--whole-module" (first a)) (recur (rest a) (assoc opts :whole-module true))
      (= "--old" (first a)) (recur (drop 2 a) (assoc opts :old (second a)))
      (= "--new" (first a)) (recur (drop 2 a) (assoc opts :new (second a)))
      (= "--name" (first a)) (recur (drop 2 a) (assoc opts :name (second a)))
      (= "--body-file" (first a)) (recur (drop 2 a) (assoc opts :body-file (second a)))
      (= "--spec-file" (first a)) (recur (drop 2 a) (assoc opts :spec-file (second a)))
      (= "--old-file" (first a)) (recur (drop 2 a) (assoc opts :old-file (second a)))
      (= "--new-file" (first a)) (recur (drop 2 a) (assoc opts :new-file (second a)))
      (= "--after" (first a)) (recur (drop 2 a) (assoc opts :after (second a)))
      (= "--text" (first a)) (recur (drop 2 a) (assoc opts :text (second a)))
      (= "--placement" (first a)) (recur (drop 2 a) (assoc opts :placement (second a)))
      :else (recur (rest a) opts))))

;; one-shot EDN request to the live coordinator daemon (the SAME wire fram-commit-code
;; uses). Returns the parsed reply map.
(defn- coord-rt [port req]
  (with-open [s (java.net.Socket.)]
    (.connect s (java.net.InetSocketAddress. "127.0.0.1" (int port)) 2000)
    (let [w (io/writer (.getOutputStream s)) rd (io/reader (.getInputStream s))]
      (.write w (str (pr-str req) "\n")) (.flush w)
      (edn/read-string (.readLine rd)))))

(let [{:keys [op module port log out no-commit whole-module old new name body-file spec-file after text placement old-file new-file]} (parse-args the-args)
      log-path (or log (str (System/getProperty "user.dir") "/.fram/code.log"))]
  (when (str/blank? op) (die "usage: bin/fram-edit-code <op> <module> [verb args] --port <P> [--log <code.log>] [--out <file>] [--no-commit] [--whole-module]\n  ops: rename --old <n> --new <n> | set-body --name <defn> --body-file <edn> | upsert-form --spec-file <edn> | insert-form --after <anchor> --spec-file <edn> | delete --name <def> | reorder --name <def> [--after <anchor>]"))
  (when (str/blank? module) (die "module is required (the @<mod># prefix to edit, e.g. schema)"))
  (when-not (.exists (io/file log-path)) (die "no code log at" log-path "(run bin/fram-ingest-code first)"))
  (when (and (not no-commit) (nil? port)) (die "--port <P> is REQUIRED unless --no-commit"))

  ;; ==========================================================================
  ;; MINIMAL-OP PATH (DEFAULT) — commit the verb's EXACT mint/supersede ops via
  ;; the LIVE warm daemon's :edit-min wire op. NO cold migrate-flat->co boot, NO
  ;; render->emit-edn->whole-module-diff. A 1-line set-body = a HANDFUL of ops, and
  ;; two disjoint same-module edits COMMUTE (they touch disjoint (te,p) groups).
  ;; Taken whenever we are committing (port given) and --whole-module was NOT set.
  ;; ==========================================================================
  (when (and port (not no-commit) (not whole-module))
    (let [spec (case op
                 "rename"      (do (when (or (str/blank? old) (str/blank? new))
                                     (die "rename needs --old <name> --new <name>"))
                                   {:op "rename" :module module :old old :new new})
                 "set-body"    (do (when (or (str/blank? name) (str/blank? body-file))
                                     (die "set-body needs --name <defn> --body-file <edn>"))
                                   (when-not (.exists (io/file body-file)) (die "no body file:" body-file))
                                   {:op "set-body" :module module :name name
                                    :datum (edn/read-string (slurp body-file))})
                 "upsert-form" (do (when (str/blank? spec-file) (die "upsert-form needs --spec-file <edn>"))
                                   (when-not (.exists (io/file spec-file)) (die "no spec file:" spec-file))
                                   {:op "upsert-form" :module module
                                    :datum (edn/read-string (slurp spec-file))})
                 "insert-form" (do (when (or (str/blank? after) (str/blank? spec-file))
                                     (die "insert-form needs --after <anchor> --spec-file <edn>"))
                                   (when-not (.exists (io/file spec-file)) (die "no spec file:" spec-file))
                                   {:op "insert-form" :module module :after after
                                    :datum (edn/read-string (slurp spec-file))})
                 "insert-comment" (do (when (or (str/blank? after) (str/blank? text))
                                        (die "insert-comment needs --after <anchor> --text <comment> [--placement leading|trailing]"))
                                      {:op "insert-comment" :module module :after after :text text :placement placement})
                 "delete"      (do (when (str/blank? name) (die "delete needs --name <def>"))
                                   {:op "delete" :module module :name name})
                 "reorder"     (do (when (str/blank? name) (die "reorder needs --name <def> [--after <anchor>]"))
                                   {:op "reorder" :module module :name name :after after})
                 "replace-in-body" (do (when (or (str/blank? name) (or (str/blank? old-file) (str/blank? new-file)))
                                         (die "replace-in-body needs --name <def> --old-file <edn> --new-file <edn>"))
                                       (when-not (.exists (io/file old-file)) (die "no old file:" old-file))
                                       (when-not (.exists (io/file new-file)) (die "no new file:" new-file))
                                       {:op "replace-in-body" :module module :name name
                                        :old (edn/read-string (slurp old-file))
                                        :new (edn/read-string (slurp new-file))})
                 (die "unknown op:" op "(rename | set-body | upsert-form | insert-form | insert-comment | delete | reorder | replace-in-body)"))]
      ;; SAFETY GATE: refuse unless the daemon serves a CODE log (never tern).
      (let [st (coord-rt port {:op :status}) daemon-log (str (:log st))]
        (when (str/blank? daemon-log) (die "coordinator on" port "reports no :log — refusing"))
        (when-not (str/includes? daemon-log "code.log")
          (die "SAFETY: coordinator on" port "serves" daemon-log "— NOT a *code.log; refusing"))
        (let [resp (coord-rt port {:op :edit-min :spec spec})]
          (if (:ok resp)
            (do (log! (str "fram-edit-code: MINIMAL-OP " op " on " module
                           " — committed " (:ops resp) " ops (" (:asserts resp) " assert / "
                           (:retracts resp) " retract; " (:new-nodes resp) " new node(s)) "
                           "THROUGH the live daemon (NOT whole-module). version -> " (:version resp)))
                ;; the log is canonical; if --out was asked, render the module from the
                ;; now-updated daemon log so the caller still gets a .bclj view.
                (when out
                  (let [r (proc/sh {:err :string :extra-env (into {} (System/getenv))}
                                   "bb" "-cp" fram-out (str bin-dir "/fram-render-code")
                                   module "--log" daemon-log "--out" out)]
                    (when (zero? (:exit r)) (log! "fram-edit-code: rendered" module "->" out))))
                (println (or out (str "@" module " committed via :edit-min")))
                (System/exit 0))
            (die "fram-edit-code: :edit-min REJECTED —" (pr-str resp)))))))

  ;; ==========================================================================
  ;; LEGACY path: --no-commit render-only, OR --whole-module commit (the baseline).
  ;; Cold-boots a store from the log in-process (kept for the render-gate pre-step
  ;; and for explicit whole-module-diff comparison).
  ;; ==========================================================================
  ;; build the verb spec from the op-specific flags.
  (let [spec (case op
               "rename"      (do (when (or (str/blank? old) (str/blank? new))
                                   (die "rename needs --old <name> --new <name>"))
                                 {:op "rename" :module module :old old :new new})
               "set-body"    (do (when (or (str/blank? name) (str/blank? body-file))
                                   (die "set-body needs --name <defn> --body-file <edn>"))
                                 (when-not (.exists (io/file body-file)) (die "no body file:" body-file))
                                 {:op "set-body" :module module :name name
                                  :datum (edn/read-string (slurp body-file))})
               "upsert-form" (do (when (str/blank? spec-file) (die "upsert-form needs --spec-file <edn>"))
                                 (when-not (.exists (io/file spec-file)) (die "no spec file:" spec-file))
                                 {:op "upsert-form" :module module
                                  :datum (edn/read-string (slurp spec-file))})
               "insert-form" (do (when (or (str/blank? after) (str/blank? spec-file))
                                   (die "insert-form needs --after <anchor> --spec-file <edn>"))
                                 (when-not (.exists (io/file spec-file)) (die "no spec file:" spec-file))
                                 {:op "insert-form" :module module :after after
                                  :datum (edn/read-string (slurp spec-file))})
               "insert-comment" (do (when (or (str/blank? after) (str/blank? text))
                                      (die "insert-comment needs --after <anchor> --text <comment> [--placement leading|trailing]"))
                                    {:op "insert-comment" :module module :after after :text text :placement placement})
               "delete"      (do (when (str/blank? name) (die "delete needs --name <def>"))
                                 {:op "delete" :module module :name name})
               "reorder"     (do (when (str/blank? name) (die "reorder needs --name <def> [--after <anchor>]"))
                                 {:op "reorder" :module module :name name :after after})
               (die "unknown op:" op "(rename | set-body | upsert-form | insert-form | insert-comment | delete | reorder)"))]

    ;; 1. boot the reified store over the code log (in-process; this IS the corpus).
    (let [coord (migrate-flat->co log-path)
          st    (:store coord)
          ;; per-run resolve-out so the verb's extract-file! projection lands here.
          resolve-out (or (System/getenv "RESOLVE_OUT")
                          (str (System/getProperty "java.io.tmpdir") "/fram-edit-" (System/nanoTime)))]
      (.mkdirs (io/file resolve-out))
      ;; confirm the module is in the log before mutating (fail-fast, clear message).
      (let [root-id (s/resolve-name st (str "@" module "#root"))]
        (when-not root-id
          (die "module" module "has no @" module "#root claim in" log-path "(was it ingested?)")))

      ;; 2. run the verb over the warm store. :resolve-out routes the verb's
      ;;    extract-file! projection into resolve-out (in-process, no env needed);
      ;;    run-verb-warm! binds *project-srcs* to the affected module so only that
      ;;    module's resolved EDN is written. NO src/fram/*.bclj is read.
      (let [affected (resolve/run-verb-warm! st (assoc spec :resolve-out resolve-out))
            proj-edn (str resolve-out "/resolved-" affected ".edn")]
        (when-not (.exists (io/file proj-edn))
          (die "verb produced no projected EDN at" proj-edn
               "(the verb may have REJECTED the edit; see stderr above)"))

        ;; 3. render the affected module FROM the projected EDN -> .bclj (ATOMIC).
        (let [r (proc/sh {:out :string :err :string} racket-bin roundtrip-rkt "--render" proj-edn)]
          (when (not (zero? (:exit r))) (die "render FAILED for" affected "\n" (:err r)))
          (let [out-file (or out (str resolve-out "/" affected ".bclj"))]
            (atomic-spit! out-file (:out r))
            (log! "fram-edit-code: rendered" affected "->" out-file
                  (str "(" (count (:out r)) " bytes; pure function of the edited log-booted store; atomic write)"))

            ;; 4. commit the AST delta THROUGH the coordinator (unless --no-commit).
            (if no-commit
              (do (log! "fram-edit-code: --no-commit — rendered only, committed NOTHING")
                  (println out-file))             ; stdout = the rendered .bclj path
              (let [commit (proc/sh {:out :string :err :string}
                                    "bb" "-cp" fram-out (str bin-dir "/fram-commit-code")
                                    affected out-file "--port" (str port))]
                (log! (str/trim (str (:out commit) (:err commit))))
                (when (not (zero? (:exit commit)))
                  (die "commit FAILED — the code log was NOT updated"))
                (log! "fram-edit-code: COMMITTED" affected
                      "— AST delta written to the code log via the coordinator (the log is canonical; .bclj is downstream)")
                (println out-file)))))))))
