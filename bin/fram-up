#!/usr/bin/env bash
# Ensure the Fram coordinator daemon is running — the "revive" half of the
# doctor handshake (analogous to `beagle-doctor --revive`). Idempotent: if a
# daemon is already up it's a no-op; otherwise it starts one (detached) on the
# canonical log and waits until it answers.
#
#   FRAM_PORT / FRAM_LOG select the port + log (default 7977, ./claims.log).
HERE="$(cd "$(dirname "$0")" && pwd)"
export FRAM_PORT="${FRAM_PORT:-7977}"
LOG="${FRAM_LOG:-$PWD/claims.log}"
RESTART=0; [ "$1" = "--restart" ] && RESTART=1

# PIDs listening on the port. fuser/lsof are NOT always installed (e.g. NixOS),
# and when they're missing the old kill silently no-opped, leaving a zombie that
# squatted the port — the new daemon then failed to bind and `up` falsely
# reported success because the zombie answered `doctor`. ss (iproute2) is
# reliably present; kill by the listener PID and VERIFY the port frees.
port_pids() { ss -tlnpH "sport = :$FRAM_PORT" 2>/dev/null | grep -oE 'pid=[0-9]+' | cut -d= -f2 | sort -u; }

if [ "$RESTART" = 1 ]; then
  echo "stopping any coordinator on :$FRAM_PORT"
  for p in $(port_pids); do kill "$p" 2>/dev/null || true; done
  for _ in $(seq 20); do [ -z "$(port_pids)" ] && break; sleep 0.1; done
  for p in $(port_pids); do kill -9 "$p" 2>/dev/null || true; done
  for _ in $(seq 20); do [ -z "$(port_pids)" ] && break; sleep 0.1; done
  if [ -n "$(port_pids)" ]; then
    echo "ERROR: :$FRAM_PORT still held by PID(s) $(port_pids | tr '\n' ' ')after SIGKILL — kill manually." >&2
    exit 1
  fi
elif "$HERE/fram" doctor 2>/dev/null | grep -q 'coordinator UP'; then
  echo "coordinator already up on :$FRAM_PORT (use \`up --restart\` to reload it)"
  exit 0
fi

echo "starting coordinator on :$FRAM_PORT  (log: $LOG)"
# Snapshot boot rides every revive: without this, an auto-revive silently boots
# flag-off and refolds the whole log (the 2026-07-03 activation race). Explicit
# FRAM_SNAPSHOT_BOOT=0 still wins; a bad checkpoint only costs a fold, never state.
export FRAM_SNAPSHOT_BOOT="${FRAM_SNAPSHOT_BOOT:-1}"
setsid "$HERE/fram-daemon" "$FRAM_PORT" "$LOG" >"/tmp/fram-daemon-$FRAM_PORT.log" 2>&1 &
disown 2>/dev/null || true

# the daemon now runs on the JVM (Clojure) — slower to boot than bb, and it reads
# the whole claim log at startup, so give it room (and a first-ever run may resolve
# deps once). ~30s ceiling; it usually answers in a few seconds.
for _ in $(seq 120); do
  if "$HERE/fram" doctor 2>/dev/null | grep -q 'coordinator UP'; then
    echo "coordinator up on :$FRAM_PORT"
    exit 0
  fi
  sleep 0.25
done
echo "ERROR: daemon did not come up — see /tmp/fram-daemon-$FRAM_PORT.log" >&2
exit 1
