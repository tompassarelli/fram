#!/usr/bin/env bash
# fram-code-wire on|off <dir> [server-json]  —  shared MERGE/UNWIRE logic for
# fram-code-on / fram-code-off. Writes/removes the fram MCP server entry in:
#   <dir>/.mcp.json                    (Claude Code, JSON  mcpServers.fram)
#   <dir>/.codex/config.toml           (Codex, TOML [mcp_servers.fram] + [.env])
# NEVER clobbers unrelated keys/sections already present in either file.
set -euo pipefail
MODE="${1:?usage: fram-code-wire on|off <dir> [server-json]}"
DIR="${2:?usage: fram-code-wire on|off <dir> [server-json]}"
SERVER_JSON="${3:-}"
MCP_JSON="$DIR/.mcp.json"
CODEX_TOML="$DIR/.codex/config.toml"

case "$MODE" in
  on)
    [ -n "$SERVER_JSON" ] || { echo "fram-code-wire on: needs server-json" >&2; exit 1; }
    # --- .mcp.json: deep-merge {mcpServers.fram: SERVER_JSON} into existing file ---
    EXISTING="{}"
    [ -f "$MCP_JSON" ] && EXISTING="$(cat "$MCP_JSON")"
    jq --argjson srv "$SERVER_JSON" '.mcpServers = ((.mcpServers // {}) + {fram: $srv})' \
      <<<"$EXISTING" > "$MCP_JSON.tmp" && mv "$MCP_JSON.tmp" "$MCP_JSON"
    # --- .codex/config.toml: replace/insert the [mcp_servers.fram] block only ---
    mkdir -p "$DIR/.codex"
    python3 "$(dirname "$0")/fram-code-wire-toml.py" set "$CODEX_TOML" "$SERVER_JSON"
    ;;
  off)
    if [ -f "$MCP_JSON" ]; then
      jq '.mcpServers |= (. // {} | del(.fram))' "$MCP_JSON" > "$MCP_JSON.tmp"
      if [ "$(jq '.mcpServers | length' "$MCP_JSON.tmp")" = "0" ] && \
         [ "$(jq 'keys - ["mcpServers"] | length' "$MCP_JSON.tmp")" = "0" ]; then
        rm -f "$MCP_JSON.tmp" "$MCP_JSON"
      else
        mv "$MCP_JSON.tmp" "$MCP_JSON"
      fi
    fi
    if [ -f "$CODEX_TOML" ]; then
      python3 "$(dirname "$0")/fram-code-wire-toml.py" unset "$CODEX_TOML"
    fi
    ;;
  *) echo "fram-code-wire: unknown mode $MODE (want on|off)" >&2; exit 1;;
esac
